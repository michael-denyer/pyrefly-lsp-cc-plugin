{
  "name": "pyrefly-lsp-cc-plugin",
  "owner": {
    "name": "Michael Denyer"
  },
  "plugins": [
    {
      "name": "pyrefly-lsp",
      "description": "Python language server (Pyrefly) — fast type checking and code intelligence",
      "version": "1.1.0",
      "author": {
        "name": "Michael Denyer"
      },
      "source": "./plugins/pyrefly-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "pyrefly": {
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/pyrefly-lsp",
          "args": [],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python"
          }
        }
      }
    }
  ]
}
